{
  "name": "locateiq",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:backup": "node scripts/nocodb-backup.mjs",
    "db:migrations": "node scripts/run-migrations.mjs --status",
    "db:migrations:apply": "node scripts/run-migrations.mjs --apply",
    "db:migrations:apply:safe": "node scripts/run-migrations.mjs --apply --backup-first",
    "db:migrations:reapply": "node scripts/run-migrations.mjs --apply --reapply",
    "db:migrate:gateway-anchor": "node scripts/nocodb-add-gateway-anchor-fields.mjs",
    "db:migrate:gateway-anchor:apply": "node scripts/nocodb-add-gateway-anchor-fields.mjs --apply",
    "db:links:add": "node scripts/nocodb-add-linked-record-columns.mjs",
    "db:links:add:apply": "node scripts/nocodb-add-linked-record-columns.mjs --apply",
    "db:links:backfill": "node scripts/nocodb-backfill-linked-records.mjs",
    "db:links:backfill:apply": "node scripts/nocodb-backfill-linked-records.mjs --apply",
    "db:docs:sync": "node scripts/nocodb-sync-project-doc-paths.mjs",
    "db:docs:sync:apply": "node scripts/nocodb-sync-project-doc-paths.mjs --apply",
    "db:vendor:url:add": "node scripts/nocodb-add-vendor-url-field.mjs",
    "db:vendor:url:add:apply": "node scripts/nocodb-add-vendor-url-field.mjs --apply",
    "db:vendor:url:sync": "node scripts/nocodb-populate-vendor-urls.mjs",
    "db:vendor:url:sync:apply": "node scripts/nocodb-populate-vendor-urls.mjs --apply",
    "db:populate:moko": "node scripts/nocodb-populate-moko-research.mjs",
    "db:populate:moko:apply": "node scripts/nocodb-populate-moko-research.mjs --apply",
    "db:anchors:links": "node scripts/nocodb-backfill-anchor-links.mjs",
    "db:anchors:links:apply": "node scripts/nocodb-backfill-anchor-links.mjs --apply",
    "db:seed:moko-additional": "node scripts/nocodb-seed-moko-additional-devices.mjs",
    "db:seed:moko-additional:apply": "node scripts/nocodb-seed-moko-additional-devices.mjs --apply",
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^8.0.0"
  }
}
